# =============================================================================
# Corvus Gateway — Environment Variables
# =============================================================================
# Copy to .env and fill in your values. All secrets are gitignored.
#
# Required vars are marked [REQUIRED]. Everything else has sane defaults.

# ---------------------------------------------------------------------------
# Core — Claude API
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=             # [REQUIRED] Your Anthropic API key
# ANTHROPIC_BASE_URL=          # Override for LiteLLM proxy (auto-set at runtime)
# ROUTER_MODEL=claude-haiku-4-5-20251001  # Model for intent router

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# HOST=0.0.0.0                 # Listen address
# PORT=18789                   # Listen port
# ALLOWED_USERS=               # Comma-separated usernames for auth
# MAX_PARALLEL_AGENT_RUNS=4    # Max concurrent agent dispatch runs
# CORVUS_BREAK_GLASS=false     # Emergency mode — bypass auth

# ---------------------------------------------------------------------------
# Data & Storage
# ---------------------------------------------------------------------------
# DATA_DIR=~/.corvus            # Root data directory
# MEMORY_DB=                    # Override SQLite memory DB path
# LOG_DIR=                      # Override log directory

# ---------------------------------------------------------------------------
# Claude Runtime Isolation
# ---------------------------------------------------------------------------
# CORVUS_CLAUDE_HOME=           # Claude CLI home directory
# CORVUS_CLAUDE_HOME_SCOPE=per_agent  # per_agent | shared
# CORVUS_CLAUDE_CONFIG_TEMPLATE=config/claude-runtime/claude.json
# CORVUS_ISOLATE_CLAUDE_HOME=1  # 1=isolate, 0=shared

# ---------------------------------------------------------------------------
# Service Credentials (injected via SOPS or set directly)
# ---------------------------------------------------------------------------

# Home Assistant
HA_URL=                        # e.g. http://homeassistant.local:8123
HA_TOKEN=                      # Long-lived access token

# Paperless-ngx
PAPERLESS_URL=                 # e.g. http://paperless.local:8000
PAPERLESS_API_TOKEN=           # API token from Paperless admin

# Firefly III
FIREFLY_URL=                   # e.g. http://firefly.local:8080
FIREFLY_API_TOKEN=             # Personal access token

# Obsidian (Local REST API plugin)
OBSIDIAN_URL=https://127.0.0.1:27124
OBSIDIAN_API_KEY=              # API key from Obsidian REST API plugin

# Google (Gmail + Drive)
GOOGLE_CREDS_PATH=             # Path to Google OAuth credentials JSON
# GMAIL_TOKEN=                  # Path to Gmail OAuth token
# GMAIL_CREDENTIALS=            # Path to Gmail credentials file
# GMAIL_ADDRESS=                # Default Gmail address
# GOOGLE_DEFAULT_ACCOUNT=       # Default Google account email

# Yahoo Mail
# YAHOO_EMAIL=                  # Yahoo email address
# YAHOO_APP_PASSWORD=           # Yahoo app password

# ---------------------------------------------------------------------------
# Webhooks
# ---------------------------------------------------------------------------
# WEBHOOK_SECRET=               # HMAC secret for webhook verification

# ---------------------------------------------------------------------------
# Config File Overrides
# ---------------------------------------------------------------------------
# SCHEDULES_CONFIG=config/schedules.yaml
# CAPABILITIES_CONFIG=config/capabilities.yaml
# TASK_ROUTING_CONFIG=config/task_routing.yaml
# MEMORY_CONFIG=config/memory.yaml

# ---------------------------------------------------------------------------
# Cognee (optional graph memory backend)
# ---------------------------------------------------------------------------
# COGNEE_DATA_DIR=/data/cognee
# COGNEE_LLM_PROVIDER=         # e.g. anthropic, openai
# COGNEE_LLM_MODEL=            # e.g. claude-sonnet-4-20250514
# COGNEE_LLM_ENDPOINT=         # Custom endpoint URL
